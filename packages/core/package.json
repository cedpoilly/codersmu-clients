{
  "name": "@codersmu/core",
  "version": "0.0.0-prototype.1",
  "description": "Exploratory shared Coders.mu client logic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cedpoilly/codersmu-clients.git"
  },
  "homepage": "https://github.com/cedpoilly/codersmu-clients#readme",
  "bugs": {
    "url": "https://github.com/cedpoilly/codersmu-clients/issues"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "license": "MIT"
}
