{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@codersmu/contracts": [
        "./packages/contracts/src/index.ts"
      ],
      "@codersmu/contracts/*": [
        "./packages/contracts/src/*"
      ],
      "@codersmu/core": [
        "./packages/core/src/index.ts"
      ],
      "@codersmu/core/*": [
        "./packages/core/src/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "packages/contracts/src/**/*.ts",
    "packages/core/src/**/*.ts",
    "tsdown.config.ts"
  ]
}
