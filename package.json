{
  "name": "codersmu",
  "version": "0.1.0",
  "description": "CLI client for coders.mu in the codersmu-clients workspace",
  "type": "module",
  "bin": {
    "codersmu": "./dist/cli.mjs",
    "cmu": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsdown",
    "build:core": "pnpm --filter @codersmu/core build",
    "build:all": "pnpm build:core && pnpm build",
    "dev": "tsdown --watch",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "typecheck:core": "pnpm --filter @codersmu/core typecheck",
    "check": "pnpm typecheck && pnpm --filter @codersmu/core check && pnpm build",
    "release:check": "pnpm check && npm pack --dry-run"
  },
  "keywords": [
    "codersmu",
    "coders.mu",
    "meetup",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsdown": "^0.16.6",
    "typescript": "^5.9.2"
  }
}
